# Google Gemini
GEMINI_API_KEY=AIza...

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=1234567890:ABC...

# Your Telegram user ID (get it from @userinfobot)
TELEGRAM_APPROVED_USER_ID=123456789

# Secret header for /api/cron — set the same value in Vercel env vars
CRON_SECRET=replace-with-random-secret

# RSS feeds (comma-separated)
RSS_FEEDS=https://techcrunch.com/feed/,https://feeds.feedburner.com/oreilly/radar/blogcomments

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
