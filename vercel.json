{
  "builds": [
    { "src": "app.py", "use": "@vercel/python", "config": { "maxLambdaSize": "15mb" } }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "app.py" }
  ],
  "functions": {
    "app.py": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/cron",
      "schedule": "30 3 * * *"
    }
  ]
}
